{
  "name": "shop",
  "version": "1.0.0",
  "description": "A modern serverless eCommerce engine using pure Web Components with built-in multilingual and multi-currency capabilities.",
  "keywords": [
    "shop",
    "ecommerce",
    "serverless",
    "web",
    "component",
    "html",
    "js",
    "javascript",
    "css"
  ],
  "homepage": "https://github.com/akaoio/shop#readme",
  "bugs": {
    "url": "https://github.com/akaoio/shop/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akaoio/shop.git"
  },
  "license": "MIT",
  "author": "mimiza",
  "type": "module",
  "scripts": {
    "start": "node build.js core && node dev.js",
    "build": "node build.js crypto && node build.js core && node build.js geo",
    "build:core": "node build.js core",
    "build:crypto": "node build.js crypto",
    "build:geo": "node build.js geo",
    "build:games": "node build.js games",
    "scan:crypto": "node scan.js",
    "scan:crypto:currencies": "node scan.js currencies",
    "scan:crypto:pools": "node scan.js pools",
    "crawl:arc-raiders": "node build.js games --game=arc-raiders",
    "crawl:diablo-4": "node build.js games --game=diablo-4",
    "fix:geo": "node builder/geo.js --fix",
    "test": "node test.js core && node test.js geo",
    "test:core": "node test.js core",
    "test:geo": "node test.js geo",
    "test:browser": "node test-browser.js",
    "dev": "node dev.js",
    "format": "prettier --write \"src/**/*.js\"",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" --fix"
  },
  "devDependencies": {
    "@akaoio/gun": "github:akaoio/gun",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "adm-zip": "^0.5.16",
    "bootstrap-icons": "^1.13.1",
    "chokidar": "^3.6.0",
    "eslint": "^9.39.2",
    "ethers": "^6.16.0",
    "ggwave": "^0.4.0",
    "prettier": "^3.7.2",
    "qrcode": "^1.5.4",
    "rollup": "^4.59.0",
    "yaml": "^2.8.2"
  }
}
