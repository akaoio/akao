{
  "name": "shop",
  "version": "1.0.0",
  "description": "A modern serverless eCommerce engine using pure Web Components with built-in multilingual and multi-currency capabilities.",
  "keywords": [
    "shop",
    "ecommerce",
    "serverless",
    "web",
    "component",
    "html",
    "js",
    "javascript",
    "css"
  ],
  "homepage": "https://github.com/akaoio/shop#readme",
  "bugs": {
    "url": "https://github.com/akaoio/shop/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akaoio/shop.git"
  },
  "license": "MIT",
  "author": "mimiza",
  "type": "module",
  "scripts": {
    "start": "node build.js && node server.js",
    "build": "node build.js",
    "serve": "node server.js",
    "geo:download": "node geo.js --download",
    "geo:build": "node geo.js --build",
    "geo:fix": "node geo.js --fix",
    "geo:test": "node geo.js --test",
    "geo:validate": "node builder/geo/validate.js",
    "format": "prettier --write \"src/**/*.js\"",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" --fix"
  },
  "devDependencies": {
    "@akaoio/gun": "github:akaoio/gun",
    "adm-zip": "^0.5.16",
    "bootstrap-icons": "^1.13.1",
    "chokidar": "^3.6.0",
    "eslint": "^9.39.2",
    "live-server": "^1.2.2",
    "prettier": "^3.7.2",
    "yaml": "^2.8.2"
  }
}
