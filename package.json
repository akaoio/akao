{
  "name": "shop",
  "version": "0.0.1",
  "description": "A modern serverless eCommerce engine using pure Web Components with built-in multilingual and multi-currency capabilities.",
  "keywords": [
    "shop",
    "ecommerce",
    "serverless",
    "web",
    "component",
    "html",
    "js",
    "javascript",
    "css"
  ],
  "homepage": "https://github.com/akaoio/shop#readme",
  "bugs": {
    "url": "https://github.com/akaoio/shop/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akaoio/shop.git"
  },
  "license": "MIT",
  "author": "mimiza",
  "type": "module",
  "scripts": {
    "start": "concurrently \"npm run market\" \"node build.js crypto && node build.js core --dev && node dev.js --https\"",
    "build": "node build.js crypto && node build.js core && node build.js index && node build.js geo && node build.js hash",
    "build:core": "node build.js core",
    "build:index": "node build.js index",
    "build:crypto": "node build.js crypto",
    "build:geo": "node build.js geo",
    "build:games": "node build.js games",
    "build:hash": "node build.js hash",
    "build:trackers": "node build.js trackers",
    "scan:crypto": "node scan.js",
    "market": "node market.js",
    "scan:crypto:currencies": "node scan.js currencies",
    "scan:crypto:pools": "node scan.js pools",
    "crawl:arc-raiders": "node build.js games --game=arc-raiders",
    "crawl:diablo-4": "node build.js games --game=diablo-4",
    "fix:geo": "node builder/geo.js --fix",
    "test": "node test.js core && node test.js geo",
    "test:core": "node test.js core",
    "test:geo": "node test.js geo",
    "test:browser": "node test-browser.js",
    "dev:ui": "node dev.js",
    "dev:https": "node dev.js --https",
    "format": "prettier --write \"src/**/*.js\"",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" --fix"
  },
  "devDependencies": {
    "@akaoio/gun": "github:akaoio/gun",
    "@sqlite.org/sqlite-wasm": "^3.51.2-build8",
    "adm-zip": "^0.5.16",
    "bootstrap-icons": "^1.13.1",
    "chokidar": "^3.6.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "ethers": "^6.16.0",
    "ggwave": "^0.4.0",
    "prettier": "^3.7.2",
    "qr-scanner": "^1.4.2",
    "selfsigned": "^5.5.0",
    "three": "^0.183.2",
    "uqr": "^0.1.2",
    "webtorrent": "^2.8.5",
    "yaml": "^2.8.2"
  }
}
